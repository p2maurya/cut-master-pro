# ============================================
# CutMaster Pro - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB - Get free at https://mongodb.com/atlas
MONGODB_URI=mongodb://localhost:27017/cutmaster_pro
# OR for MongoDB Atlas (free cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cutmaster_pro

# JWT Secret - Change this to a random long string!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=30d

# File Upload
MAX_FILE_SIZE=524288000
UPLOAD_PATH=./uploads

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: Email (for password reset)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=your@gmail.com
# SMTP_PASSWORD=yourapppassword
